<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Bazar d'Infrep - Magasin Pédagogique</title>
    <style>
        /* Styles Généraux */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f8f9fa;
            color: #333;
            line-height: 1.6;
        }

        /* Barre de Navigation */
        header {
            background-color: #2c3e50;
            color: #fff;
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #e67e22;
        }

        nav ul {
            display: flex;
            list-style: none;
        }

        nav ul li {
            margin-left: 20px;
        }

        nav ul li a {
            color: #fff;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        nav ul li a:hover {
            color: #e67e22;
        }

        /* Section Héro (Accueil) */
        .hero {
            background: linear-gradient(rgba(44, 62, 80, 0.85), rgba(44, 62, 80, 0.85)), url('https://images.unsplash.com/photo-1542838132-92c53300491e?q=80&w=1000') no-repeat center center/cover;
            color: #fff;
            height: 350px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 1rem;
        }

        .hero h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            max-width: 600px;
        }

        /* Section Présentation */
        .about {
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
            text-align: center;
        }

        .about h2 {
            color: #2c3e50;
            margin-bottom: 15px;
        }

        /* Grille des Produits / Rayons */
        .products-section {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .products-section h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #2c3e50;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .product-card {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
            transition: transform 0.3s, box-shadow 0.3s;
            text-align: center;
            padding-bottom: 20px;
            border: 1px solid #eef2f3;
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        }

        .product-img {
            width: 100%;
            height: 180px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: bold;
            font-size: 1.3rem;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
            margin-bottom: 15px;
        }

        .product-card h3 {
            margin: 5px 10px;
            font-size: 1.2rem;
            color: #2c3e50;
        }

        .product-tag {
            display: inline-block;
            font-size: 0.85rem;
            background: #eef2f3;
            color: #7f8c8d;
            padding: 4px 12px;
            border-radius: 20px;
            margin-top: 5px;
            margin-bottom: 15px;
        }

        /* Pied de page */
        footer {
            background-color: #2c3e50;
            color: #fff;
            text-align: center;
            padding: 25px;
            margin-top: 60px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <header>
        <div class="nav-container">
            <div class="logo">Le Bazar d'Infrep</div>
            <nav>
                <ul>
                    <li><a href="#accueil">Accueil</a></li>
                    <li><a href="#concept">Notre Concept</a></li>
                    <li><a href="#rayons">Nos Rayons</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Accueil -->
    <section id="accueil" class="hero">
        <h1>Le Bazar d'Infrep</h1>
        <p>Notre espace de formation pédagogique dédié aux métiers du commerce, de la vente et de la mise en rayon.</p>
    </section>

    <!-- Concept -->
    <section id="concept" class="about">
        <h2>Boutique École</h2>
        <p>Du balisage à l'implantation des produits, nous gérons ce magasin de A à Z pour parfaire nos techniques de mise en rayon et d'organisation.</p>
    </section>

    <!-- Grille des Rayons -->
    <section id="rayons" class="products-section">
        <h2>Articles & Rayons du Magasin</h2>
        <div class="product-grid">
            
            <!-- Vêtements -->
            <div class="product-card">
                <div class="product-img" style="background-color: #34495e;">Prêt-à-porter</div>
                <h3>Veste de Saison</h3>
                <span class="product-tag">Rayon Textile</span>
            </div>

            <!-- TV / Multimédia -->
            <div class="product-card">
                <div class="product-img" style="background-color: #2c3e50;">Multimédia</div>
                <h3>Téléviseur LED 4K</h3>
                <span class="product-tag">Rayon Électronique</span>
            </div>

            <!-- Parfum -->
            <div class="product-card">
                <div class="product-img" style="background-color: #9b59b6;">Parfumerie</div>
                <h3>Eau de Parfum (Prestige)</h3>
                <span class="product-tag">Rayon Beauté</span>
            </div>

            <!-- Shampoing Homme -->
            <div class="product-card">
                <div class="product-img" style="background-color: #2980b9;">Hygiène Homme</div>
                <h3>Shampoing Fortifiant</h3>
                <span class="product-tag">DPH (Droguerie Parfumerie Hygiène)</span>
            </div>

            <!-- Shampoing Femme -->
            <div class="product-card">
                <div class="product-img" style="background-color: #1abc9c;">Hygiène Femme</div>
                <h3>Shampoing Éclat</h3>
                <span class="product-tag">DPH (Droguerie Parfumerie Hygiène)</span>
            </div>

            <!-- Livres -->
            <div class="product-card">
                <div class="product-img" style="background-color: #e67e22;">Librairie</div>
                <h3>Roman Best-Seller</h3>
                <span class="product-tag">Rayon Culture</span>
            </div>

            <!-- Lunettes -->
            <div class="product-card">
                <div class="product-img" style="background-color: #16a085;">Optique</div>
                <h3>Lunettes de Soleil</h3>
                <span class="product-tag">Rayon Accessoires</span>
            </div>

            <!-- Bijouterie -->
            <div class="product-card">
                <div class="product-img" style="background-color: #f1c40f; color: #333;">Bijouterie</div>
                <h3>Bracelet Élégance</h3>
                <span class="product-tag">Rayon Accessoires de Luxe</span>
            </div>

        </div>
    </section>

    <!-- Pied de page -->
    <footer id="contact">
        <p>&copy; 2026 Le Bazar d'Infrep - Espace de Formation Professionnelle.</p>
    </footer>

</body>
</html>